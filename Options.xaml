<ResourceDictionary
    x:Class="JeffRidder.NINA.Nightfront.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  This data template is displayed in N.I.N.A. on the options->plugin tab with the datacontext of the Nightfront instance  -->
    <!--  In order for this datatemplate to be picked correctly, the key has to follow the naming convention of <IPlugin.Name>_Options -->
    <!--  Furthermore the Resource Dictionary has to be exported via code behind export attributes  -->
    <DataTemplate x:Key="NightFront_Options">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="NightFront Data Folder" />
                <TextBox
                    MinWidth="250"
                    Margin="5,0,0,0"
                    IsReadOnly="True"
                    Text="{Binding NightFrontDataFolder, Mode=OneWay}" />
                <Button
                    Margin="5,0,0,0"
                    Command="{Binding SelectNightFrontDataFolderCommand}"
                    Content="Browse..." />
            </StackPanel>
            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text='Flat Filter Order (e.g., &quot;L, B, G, R, OIII, Ha, SII&quot;)' />
                <TextBox
                    MinWidth="250"
                    Margin="5,0,0,0"
                    ToolTip="Comma-separated filter names, e.g. L, B, G, R, OIII, Ha, SII. Determines the order sky/trained flats are shot in, regardless of the order in the calibration-metadata file. Leave blank to use the order requirements were recorded."
                    Text="{Binding FlatFilterOrder, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Flat Refresh Days" />
                <TextBox
                    MinWidth="50"
                    Margin="5,0,0,0"
                    ToolTip="Number of days after a calibration requirement's flats were completed before it's dropped so it can be reshot."
                    Text="{Binding FlatRefreshDays, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="Replan Effort Level" />
                <ComboBox
                    MinWidth="120"
                    Margin="5,0,0,0"
                    ToolTip="GA compute budget for an unattended safety-recovery replan. Defaults to Fast since most imaging PCs run overnight on modest hardware (a mini-PC or NUC on the mount) - only pick Balanced/Thorough if this machine is a genuinely capable desktop."
                    ItemsSource="{Binding ReplanEffortLevelOptions}"
                    SelectedItem="{Binding ReplanEffortLevel, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="NightFront CLI Path" />
                <TextBox
                    MinWidth="250"
                    Margin="5,0,0,0"
                    IsReadOnly="True"
                    ToolTip="Path to the NightFront CLI executable, or a wrapper script that launches it (e.g. a .bat running `java -jar NightFront.jar %*`). Used by Replan After Safety Recovery to re-solve the remainder of the night."
                    Text="{Binding NightFrontCliPath, Mode=OneWay}" />
                <Button
                    Margin="5,0,0,0"
                    Command="{Binding SelectNightFrontCliPathCommand}"
                    Content="Browse..." />
            </StackPanel>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>