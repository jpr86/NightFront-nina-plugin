<ResourceDictionary
    x:Class="JeffRidder.NINA.Nightfront.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  This data template is displayed in N.I.N.A. on the options->plugin tab with the datacontext of the Nightfront instance  -->
    <!--  In order for this datatemplate to be picked correctly, the key has to follow the naming convention of <IPlugin.Name>_Options -->
    <!--  Furthermore the Resource Dictionary has to be exported via code behind export attributes  -->
    <DataTemplate x:Key="NightFront_Options">
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="NightFront Data Folder" />
                <TextBox
                    MinWidth="250"
                    Margin="5,0,0,0"
                    IsReadOnly="True"
                    Text="{Binding NightFrontDataFolder, Mode=OneWay}" />
                <Button
                    Margin="5,0,0,0"
                    Command="{Binding SelectNightFrontDataFolderCommand}"
                    Content="Browse..." />
            </StackPanel>
        </StackPanel>
    </DataTemplate>
</ResourceDictionary>