<ResourceDictionary
    x:Class="JeffRidder.NINA.Nightfront.Sequencer.NightFrontSequencerTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:JeffRidder.NINA.Nightfront.Converters"
    xmlns:local="clr-namespace:JeffRidder.NINA.Nightfront.Sequencer"
    xmlns:mini="clr-namespace:NINA.View.Sequencer.MiniSequencer;assembly=NINA.Sequencer"
    xmlns:nina="clr-namespace:NINA.View.Sequencer;assembly=NINA.Sequencer"
    xmlns:ninactrl="clr-namespace:NINA.CustomControlLibrary;assembly=NINA.CustomControlLibrary"
    xmlns:behaviors="clr-namespace:NINA.Sequencer.Behaviors;assembly=NINA.Sequencer"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <conv:NightFrontRunStatusToBrushConverter x:Key="NightFrontRunStatusToBrushConverter" />
    <conv:SequenceEntityStatusToBrushConverter x:Key="SequenceEntityStatusToBrushConverter" />
    <conv:InputCoordinatesToRaDecTextConverter x:Key="InputCoordinatesToRaDecTextConverter" />
    <conv:TargetTimeWindowConverter x:Key="TargetTimeWindowConverter" />
    <conv:NightFrontPercentageConverter x:Key="NightFrontPercentageConverter" />

    <!--  Shared icon for both NightFront sequencer classes: a monochrome silhouette of the app's
          comet mark (Resources\NightFrontIcon.png) - a rounded diagonal tail capped by a circular
          head. No Fill is set so NINA's palette applies its own themed icon-foreground brush. -->
    <GeometryGroup x:Key="NightFront_SVG" FillRule="Nonzero">
        <EllipseGeometry Center="150,55" RadiusX="26" RadiusY="26" />
        <RectangleGeometry Rect="0,0,150,32" RadiusX="16" RadiusY="16">
            <RectangleGeometry.Transform>
                <TransformGroup>
                    <RotateTransform Angle="-35" CenterX="0" CenterY="0" />
                    <TranslateTransform X="20" Y="165" />
                </TransformGroup>
            </RectangleGeometry.Transform>
        </RectangleGeometry>
    </GeometryGroup>

    <!--  The NightFront app's own icon (Resources\NightFrontIcon.png), used for in-block branding  -->
    <BitmapImage x:Key="NightFrontAppIconImage" UriSource="pack://application:,,,/JeffRidder.NINA.Nightfront;component/Resources/NightFrontIcon.png" />

    <!--  NightFront Container: per-target summary row (used when the item is a target) and a
          minimal fallback row (used for any other imported top-level instruction type - see
          NightFrontTargetRowTemplateSelector). Named/keyed rather than DataType-keyed since this
          ResourceDictionary is merged app-wide; an implicit DataType template for
          DeepSkyObjectContainer would hijack NINA's own rendering of that type everywhere else. -->
    <DataTemplate x:Key="NightFrontTargetSummaryRow">
        <StackPanel Margin="0,2" Orientation="Horizontal">
            <Ellipse
                Width="8"
                Height="8"
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                Fill="{Binding Status, Converter={StaticResource SequenceEntityStatusToBrushConverter}}" />
            <TextBlock
                Width="140"
                VerticalAlignment="Center"
                Text="{Binding Name}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                Width="160"
                VerticalAlignment="Center"
                Opacity="0.85"
                Text="{Binding Coordinates, Converter={StaticResource InputCoordinatesToRaDecTextConverter}}" />
            <TextBlock
                Width="80"
                VerticalAlignment="Center"
                Opacity="0.85"
                Text="{Binding RotationAngle, StringFormat='Rot: {0:0.0}°'}" />
            <TextBlock
                Width="140"
                VerticalAlignment="Center"
                Opacity="0.85">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource TargetTimeWindowConverter}">
                        <Binding Path="WindowStart" />
                        <Binding Path="WindowEnd" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            <TextBlock VerticalAlignment="Center" Opacity="0.85">
                <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0}/{1} subs">
                        <Binding Path="CompletedCount" />
                        <Binding Path="PlannedCount" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="NightFrontGenericSummaryRow">
        <StackPanel Margin="0,2" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Opacity="0.85" Text="{Binding Name}" />
        </StackPanel>
    </DataTemplate>

    <local:NightFrontTargetRowTemplateSelector
        x:Key="NightFrontTargetRowTemplateSelector"
        GenericRowTemplate="{StaticResource NightFrontGenericSummaryRow}"
        TargetRowTemplate="{StaticResource NightFrontTargetSummaryRow}" />

    <!--  NightFront Container: holds the instructions imported from a NightFront plan file. The icon
          and name are already shown by the sequencer's own chrome to the left of this content, so
          no icon is repeated here. -->
    <DataTemplate DataType="{x:Type local:NightFrontContainer}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding Items.Count, StringFormat='{}{0} target(s) scheduled'}" />
                    <ItemsControl
                        Margin="25,4,0,0"
                        ItemTemplateSelector="{StaticResource NightFrontTargetRowTemplateSelector}"
                        ItemsSource="{Binding TargetSummaries}" />
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontContainer_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Margin="0,0,5,0"
                        Source="{StaticResource NightFrontAppIconImage}" />
                    <TextBlock VerticalAlignment="Center" Text="NightFront" />
                </StackPanel>
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!--  Nightly Update: checks for and imports today's NightFront plan file. The icon and name are
          already shown by the sequencer's own chrome to the left of this content, so this only adds
          the status readout; the instruction's description lives in a ToolTip instead of inline
          text. -->
    <DataTemplate DataType="{x:Type local:NightFrontUpdateInstruction}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Horizontal" ToolTip="Checks the configured NightFront folder for today's plan file and, if found, populates the following NightFront Container with it.">
                    <Ellipse
                        Width="10"
                        Height="10"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Fill="{Binding LastRunSucceeded, Converter={StaticResource NightFrontRunStatusToBrushConverter}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontStyle="Italic"
                        Opacity="0.85"
                        Text="{Binding StatusMessage}" />
                    <TextBlock
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="11"
                        Opacity="0.6"
                        Text="{Binding LastRunTimestamp, StringFormat='Last checked: {0:MMM d, h:mm tt}'}" />
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontUpdateInstruction_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Margin="0,0,5,0"
                        Source="{StaticResource NightFrontAppIconImage}" />
                    <TextBlock VerticalAlignment="Center" Text="Nightly Update" />
                    <Ellipse
                        Width="8"
                        Height="8"
                        Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Fill="{Binding LastRunSucceeded, Converter={StaticResource NightFrontRunStatusToBrushConverter}}" />
                </StackPanel>
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <!--  Shared row naming the single, fixed calibration-metadata file every NightFront calibration
          instruction/condition reads from and writes to (see NightFrontMetadataPaths).  -->
    <DataTemplate x:Key="NightFrontMetadataFileRow">
        <TextBlock
            Opacity="0.85"
            FontStyle="Italic"
            Text="Metadata file: calibration.metadata.json" />
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontRotateToNextAngleInstruction}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontMetadataFileRow}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontRotateToNextAngleInstruction_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock VerticalAlignment="Center" Text="NightFront Rotate to Next Angle" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontSkyFlatsInstruction}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontMetadataFileRow}" />
                    <WrapPanel Orientation="Horizontal">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Min exposure" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="s"
                            Text="{Binding MinExposure}"
                            TextAlignment="Right" />
                        <TextBlock Margin="7.5,0,7.5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="|" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Max exposure" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="s"
                            Text="{Binding MaxExposure}"
                            TextAlignment="Right" />
                        <TextBlock Margin="7.5,0,7.5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="|" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Mean target" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="%"
                            Text="{Binding HistogramTargetPercentage, Converter={StaticResource NightFrontPercentageConverter}, UpdateSourceTrigger=PropertyChanged}"
                            TextAlignment="Right" />
                        <TextBlock Margin="7.5,0,7.5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="|" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Mean tolerance" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="%"
                            Text="{Binding HistogramTolerancePercentage, Converter={StaticResource NightFrontPercentageConverter}, UpdateSourceTrigger=PropertyChanged}"
                            TextAlignment="Right" />
                        <TextBlock Margin="7.5,0,7.5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="|" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Dither" />
                        <CheckBox Margin="5,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ShouldDither}" />
                        <TextBlock Margin="7.5,0,7.5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="|" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Amount" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Text="{Binding Amount}"
                            TextAlignment="Right" />
                    </WrapPanel>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontSkyFlatsInstruction_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock VerticalAlignment="Center" Text="NightFront Sky Flats" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontTrainedFlatsInstruction}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontMetadataFileRow}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Text="Amount" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Text="{Binding Amount}"
                            TextAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontTrainedFlatsInstruction_Mini">
        <mini:MiniSequenceItem>
            <mini:MiniSequenceItem.SequenceItemContent>
                <TextBlock VerticalAlignment="Center" Text="NightFront Trained Flats" />
            </mini:MiniSequenceItem.SequenceItemContent>
        </mini:MiniSequenceItem>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontWhileSameRotationCondition}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontMetadataFileRow}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontWhileSameRotationCondition_Mini">
        <mini:MiniCondition>
            <mini:MiniCondition.ConditionProgressContent>
                <TextBlock VerticalAlignment="Center" Text="While Same Rotation" />
            </mini:MiniCondition.ConditionProgressContent>
        </mini:MiniCondition>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontWhileCalibrationRemainsCondition}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontMetadataFileRow}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontWhileCalibrationRemainsCondition_Mini">
        <mini:MiniCondition>
            <mini:MiniCondition.ConditionProgressContent>
                <TextBlock VerticalAlignment="Center" Text="While Calibration Remains" />
            </mini:MiniCondition.ConditionProgressContent>
        </mini:MiniCondition>
    </DataTemplate>

    <!--  Seeing Trigger: threshold/comparator/interval fields, a live FWHM/status readout, and a
          TriggerRunner drop area for the user's own action instructions. The drop area's
          DragOverBehavior/DropIntoBehavior wiring is adapted from palmito9/Nina.SequencerPlus's
          DIYMeridianFlipTrigger (a real, published plugin confirmed to target the same
          NINA.Plugin 3.2.0.9001 this was verified against) - upstream NINA's own CustomTrigger
          mechanism isn't available in any NINA version this plugin targets or that's deployed.
          TriggerRunner is a plain SequentialContainer, which already implements IDropContainer, so
          DropIntoCommand below needs no code in NightFrontSeeingTrigger itself.  -->
    <DataTemplate DataType="{x:Type local:NightFrontSeeingTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <StackPanel Orientation="Vertical">
                    <WrapPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Text="Fire when FWHM" />
                        <ComboBox
                            MinWidth="60"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            SelectedValue="{Binding Comparator}"
                            SelectedValuePath="Tag">
                            <ComboBoxItem Content="&lt;=" Tag="{x:Static local:SeeingComparator.LessThanOrEqual}" />
                            <ComboBoxItem Content="&gt;=" Tag="{x:Static local:SeeingComparator.GreaterThanOrEqual}" />
                        </ComboBox>
                        <ninactrl:UnitTextBox
                            MinWidth="50"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="&quot;"
                            Text="{Binding ThresholdArcsec}"
                            TextAlignment="Right" />
                        <TextBlock Margin="10,0,5,0" VerticalAlignment="Center" Text="Poll every" />
                        <ninactrl:UnitTextBox
                            MinWidth="40"
                            Margin="0,0,5,0"
                            VerticalAlignment="Center"
                            ninactrl:UnitTextBox.Unit="min"
                            Text="{Binding PollingIntervalMinutes}"
                            TextAlignment="Right" />
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,5,0" VerticalAlignment="Center" Text="Data source override (blank = plugin default)" />
                        <TextBox
                            MinWidth="200"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            Text="{Binding DataSourceUrlOverride, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,4,0,0"
                        FontStyle="Italic"
                        Opacity="0.85"
                        Text="{Binding StatusMessage}" />
                    <Border
                        MinHeight="35"
                        Margin="0,6,0,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                        <Grid Background="{StaticResource BackgroundBrush}" DataContext="{Binding TriggerRunner}">
                            <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontStyle="Italic"
                                Opacity="0.4"
                                Text="Instructions will go here..."
                                Visibility="{Binding Items.Count, Converter={StaticResource InverseZeroToVisibilityConverter}}" />
                            <i:Interaction.Behaviors>
                                <behaviors:DragOverBehavior DragAboveSize="0" DragBelowSize="0" />
                                <behaviors:DropIntoBehavior
                                    AllowedDragDropTypesString="NINA.Sequencer.Container.ISequenceContainer;NINA.Sequencer.SequenceItem.ISequenceItem;NINA.Sequencer.TemplatedSequenceContainer"
                                    OnDropCommand="DropIntoCommand" />
                            </i:Interaction.Behaviors>
                        </Grid>
                    </Border>
                </StackPanel>
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontSeeingTrigger_Mini">
        <mini:MiniTrigger />
    </DataTemplate>

    <!--  Before Target / After Target: fire around each NightFront-planned target
          (NightFrontTargetTriggerBase) and run whatever instructions the user drops below - same
          TriggerRunner drop-area pattern as the Seeing Trigger above (DIYMeridianFlipTrigger's
          DragOverBehavior/DropIntoBehavior wiring), but with no threshold/comparator fields of their
          own - just a live target/status readout. Shared as one content template since both triggers
          render identically (mirrors the NightFrontMetadataFileRow reuse pattern above).  -->
    <DataTemplate x:Key="NightFrontTargetTriggerStatusRow">
        <StackPanel Orientation="Vertical">
            <TextBlock
                FontStyle="Italic"
                Opacity="0.85"
                Text="{Binding StatusMessage}" />
            <Border
                MinHeight="35"
                Margin="0,6,0,0"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
                <Grid Background="{StaticResource BackgroundBrush}" DataContext="{Binding TriggerRunner}">
                    <ItemsControl MinHeight="35" ItemsSource="{Binding Items}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontStyle="Italic"
                        Opacity="0.4"
                        Text="Instructions will go here..."
                        Visibility="{Binding Items.Count, Converter={StaticResource InverseZeroToVisibilityConverter}}" />
                    <i:Interaction.Behaviors>
                        <behaviors:DragOverBehavior DragAboveSize="0" DragBelowSize="0" />
                        <behaviors:DropIntoBehavior
                            AllowedDragDropTypesString="NINA.Sequencer.Container.ISequenceContainer;NINA.Sequencer.SequenceItem.ISequenceItem;NINA.Sequencer.TemplatedSequenceContainer"
                            OnDropCommand="DropIntoCommand" />
                    </i:Interaction.Behaviors>
                </Grid>
            </Border>
        </StackPanel>
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontBeforeTargetTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontTargetTriggerStatusRow}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontBeforeTargetTrigger_Mini">
        <mini:MiniTrigger />
    </DataTemplate>

    <DataTemplate DataType="{x:Type local:NightFrontAfterTargetTrigger}">
        <nina:SequenceBlockView>
            <nina:SequenceBlockView.SequenceItemContent>
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource NightFrontTargetTriggerStatusRow}" />
            </nina:SequenceBlockView.SequenceItemContent>
        </nina:SequenceBlockView>
    </DataTemplate>

    <DataTemplate x:Key="JeffRidder.NINA.Nightfront.Sequencer.NightFrontAfterTargetTrigger_Mini">
        <mini:MiniTrigger />
    </DataTemplate>
</ResourceDictionary>
